<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>T0KENUMBERS</title>
<style>
  html,body { margin:0; height:100%; background:#0b1220; overscroll-behavior:none; }
  #canvas { display:block; width:100vw; height:100vh; touch-action:none; }
</style>
</head>
<body>
  <canvas id="canvas" tabindex="0"></canvas>
  <input id="ime" type="text" inputmode="text" autocomplete="off" autocapitalize="off" autocorrect="off"
         style="position:fixed;left:-9999px;width:1px;height:1px;opacity:0.01;border:0;background:transparent;font-size:16px;" />

  <script>
    // --- Canvas/IME setup ---
    const canvas = document.getElementById('canvas');
    const IME    = document.getElementById('ime');
    window.IME   = IME;

    function fitCanvasToWindow() {
      const dpr = window.devicePixelRatio || 1;
      const w = Math.max(1, Math.floor(window.innerWidth  * dpr));
      const h = Math.max(1, Math.floor(window.innerHeight * dpr));
      if (canvas.width  !== w) canvas.width  = w;
      if (canvas.height !== h) canvas.height = h;
    }
    fitCanvasToWindow();
    addEventListener('resize', fitCanvasToWindow);
    addEventListener('orientationchange', fitCanvasToWindow);

    if (typeof document.exitPointerLock !== "function") document.exitPointerLock = function(){};
    if (typeof HTMLCanvasElement.prototype.requestPointerLock !== "function") HTMLCanvasElement.prototype.requestPointerLock = function(){};

    function focusCanvas(){ try { canvas.focus({preventScroll:true}); } catch(e){} }
    canvas.addEventListener('mouseenter', focusCanvas);
    canvas.addEventListener('mousedown',  focusCanvas);
    canvas.addEventListener('touchstart', focusCanvas, { passive:true });

    // IME -> C++
    IME.addEventListener('input', () => {
      const s = IME.value;
      if (s && window.Module && Module.ccall) {
        Module.ccall('ime_send', null, ['string'], [s]);
        IME.value = '';
      }
    });
    IME.addEventListener('keydown', (e)=>{ if (e.key === 'Enter') IME.blur(); });
    ['touchstart','mousedown'].forEach(ev =>
      document.addEventListener(ev, (e)=>{
        if (document.activeElement === IME && e.target !== IME) IME.blur();
      }, {passive:true})
    );

    // --- Tek Module tanımı + versiyon bust ---
    const VER = "2025-09-18-6"; // her build'de değiştir
    window.Module = {
      canvas,
      locateFile: (p) => p + (p.endsWith('.wasm') ? ('?v=' + VER) : ''), // WASM için bust
      onRuntimeInitialized(){ focusCanvas(); },
      print:    (t)=>console.log(t),
      printErr: (t)=>console.error(t),
    };
  </script>

  <!-- Sadece TEK JS include -->
  <script src="./t0kenumbers.js?v=2025-09-18-6"></script>
</body>
</html>
